{
  "name": "VendoMas",
  "version": "1.0.0",
  "description": "Sistema de gestión para pequeños comercios",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "npx terser www/script.js -o www/script.js -c -m && npx cap sync android"
  },
  "build": {
    "appId": "com.vendomas.app",
    "productName": "VendoMas",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.0.12",
    "terser": "^5.48.0"
  },
  "dependencies": {
    "@capacitor-mlkit/barcode-scanning": "^8.1.0",
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/device": "^8.0.2",
    "@capacitor/splash-screen": "^8.0.1"
  }
}
